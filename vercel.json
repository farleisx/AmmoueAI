// vercel.json
{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        },
        {
          "key": "Content-Security-Policy",
          "value": "frame-ancestors 'self';"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/api/deploy", "destination": "/api/deploy.js" },
    { "source": "/", "destination": "/index.prod.html" },
    { "source": "/login", "destination": "/login.prod.html" },
    { "source": "/dashboard", "destination": "/dashboard.prod.html" },
    { "source": "/ai_prompt", "destination": "/ai_prompt.prod.html" },
    { "source": "/upgrade", "destination": "/upgrade.prod.html" },
    { "source": "/editor", "destination": "/editor.prod.html" },
    { "source": "/terms", "destination": "/terms.prod.html" },
    { "source": "/privacy", "destination": "/privacy.prod.html" },
    { "source": "/about", "destination": "/about.prod.html" },
    { "source": "/contact", "destination": "/contact.prod.html" },
    { "source": "/careers", "destination": "/careers.prod.html" },
    { "source": "/plans-and-credits", "destination": "/plans-and-credits.prod.html" },
    { "source": "/profile", "destination": "/profile.prod.html" }
  ]
}
