{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        },
        {
          "key": "Content-Security-Policy",
          "value": "frame-ancestors 'self';"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ],
  "routes": [
    { "src": "^/api/(.*)", "dest": "/api/$1" },
    
    { "src": "^/api/deploy$", "dest": "/api/deploy.js" },
    { "src": "^/$", "dest": "/index.prod.html" },
    { "src": "^/login$", "dest": "/login.prod.html" },
    { "src": "^/dashboard$", "dest": "/dashboard.prod.html" },
    { "src": "^/ai_prompt$", "dest": "/ai_prompt.prod.html" },
    { "src": "^/upgrade$", "dest": "/upgrade.prod.html" },
    { "src": "^/editor$", "dest": "/editor.prod.html" },
    { "src": "^/terms$", "dest": "/terms.prod.html" },
    { "src": "^/privacy$", "dest": "/privacy.prod.html" },
    { "src": "^/about$", "dest": "/about.prod.html" },
    { "src": "^/contact$", "dest": "/contact.prod.html" },
    { "src": "^/careers$", "dest": "/careers.prod.html" },
    { "src": "^/plans-and-credits$", "dest": "/plans-and-credits.prod.html" },
    { "src": "^/profile$", "dest": "/profile.prod.html" }
  ]
}
